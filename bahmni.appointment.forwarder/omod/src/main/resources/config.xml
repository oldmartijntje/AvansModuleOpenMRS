	</privilege>
	 /Required Privileges -->


	<!-- Required Global Properties -->
	<globalProperty>
		<property>communicatie.tenantId</property>
		<defaultValue></defaultValue>
		<description>
			Unique identifier for this OpenMRS tenant in the communication module.
			Set this during onboarding. Example: hospital-amsterdam
		</description>
	</globalProperty>

	<globalProperty>
    	<property>communicatie.rabbitmq.url</property>
    	<defaultValue></defaultValue>
    	<description>
        	Connection URL for the central RabbitMQ instance.
        	Format: amqp://username:password@host:port/
        	Set this via the OpenMRS admin interface, never hardcode credentials here.
    	</description>
	</globalProperty>
	<globalProperty>
    	<property>communicatie.encryption.key</property>
    	<defaultValue></defaultValue>
    	<description>
        	AES-256 encryption key for encrypting message payloads before publishing to RabbitMQ.
        	Must be exactly 32 characters.
    	</description>
	</globalProperty>
	
